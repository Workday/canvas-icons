{
  "name": "canvas-icons",
  "version": "0.0.0",
  "description": "Canvas system and expressive icons",
  "main": "index.js",
  "repository": "git@github.com:Workday/canvas-icons.git",
  "author": "Workday, Inc. (https://www.workday.com)",
  "license": "CC-BY-ND-4.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.26.2",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/next": "22.5.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@workday/canvas-kit-react": "^14.2.20",
    "@workday/canvas-system-icons-web": "^3.0.37",
    "@workday/canvas-tokens-web": "^4.1.0",
    "@workday/design-assets-types": "^0.2.10",
    "change-case-all": "^2.1.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^2.4.0",
    "lint-staged": "^15.4.3",
    "npm-run-all": "^4.1.5",
    "nx": "22.5.4",
    "prettier": "^3.8.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "prepare": "husky",
    "docs:build": "nx build @workday/canvas-icons-docs",
    "docs:dev": "nx dev @workday/canvas-icons-docs",
    "docs:run": "nx start @workday/canvas-icons-docs",
    "graph": "nx graph",
    "lint": "eslint .",
    "precommit": "lint-staged",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier \"**/*.{js,jsx,json,scss,md}\" --write"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --cache --fix", "prettier --write"],
    "*.md": "prettier --write"
  }
}
