{
  "name": "canvas-icons",
  "version": "0.0.0",
  "description": "Canvas system and expressive icons",
  "main": "index.js",
  "repository": "git@github.com:Workday/canvas-icons.git",
  "author": "Workday, Inc. (https://www.workday.com)",
  "license": "CC-BY-ND-4.0",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/next": "22.5.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@workday/canvas-kit-react": "^14.2.20",
    "@workday/canvas-system-icons-web": "^3.0.37",
    "@workday/canvas-tokens-web": "^4.1.0",
    "@workday/design-assets-types": "^0.2.10",
    "change-case-all": "^2.1.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^2.4.0",
    "npm-run-all": "^4.1.5",
    "nx": "22.5.4",
    "prettier": "^3.8.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "zod": "4.3.6"
  },
  "scripts": {
    "build": "run-p build:system build:expressive",
    "build:system": "run-s build:base:system build:web:system",
    "build:expressive": "run-s build:base:expressive build:web:expressive",
    "build:base": "nx run @workday/canvas-icons:build",
    "build:base:system": "nx run @workday/canvas-icons:build:system",
    "build:base:expressive": "nx run @workday/canvas-icons:build:expressive",
    "build:web": "nx run-many -t build --projects=tag:platform:web",
    "build:web:system": "nx run @workday/canvas-system-icons-web:build",
    "build:web:expressive": "nx run @workday/canvas-expressive-icons-web:build",
    "clean": "nx run-many -t clean --projects=tag:*:*",
    "docs:build": "nx build @workday/canvas-icons-docs",
    "docs:dev": "nx dev @workday/canvas-icons-docs",
    "docs:run": "nx start @workday/canvas-icons-docs",
    "format": "prettier \"**/*.{js,jsx,json,scss,md}\" --write",
    "graph": "nx graph",
    "lint": "eslint .",
    "prepare": "husky",
    "predocs:dev": "yarn build",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "private": true
}
