{
  "name": "@workday/canvas-system-icons-web",
  "version": "4.0.4",
  "description": "Workday system icons for web",
  "license": "CC-BY-ND-4.0",
  "author": "Workday, Inc. (https://www.workday.com)",
  "contributors": [
    "Alan Smith",
    "Josh Bagwell",
    "Manuel Carrera",
    "Raisa Primerova",
    "Sheelah Brennan"
  ],
  "main": "dist/commonjs/index.js",
  "module": "dist/es6/index.js",
  "sideEffects": false,
  "types": "dist/es6/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "run-s clean build:base build:copy build:js build:sprites",
    "build:base": "nx build:system @workday/canvas-icons",
    "build:copy": "mkdir -p dist/svg && cp ../canvas-icons/dist/svg/system/*.svg ./dist/svg",
    "build:js": "nx run-many -t icon-es6 icon-commonjs -p @workday/canvas-system-icons-web",
    "build:sprites": "nx run-many -t sprites -p @workday/canvas-system-icons-web",
    "clean": "rimraf dist",
    "pb": "cd ../.. && changeset publish"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "private": true
}
