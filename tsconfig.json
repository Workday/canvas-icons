{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "jsx": "react",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "moduleResolution": "nodenext"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "ES2022"
    }
  }
}
